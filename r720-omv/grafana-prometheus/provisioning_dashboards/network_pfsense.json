{
  "uid": "infra-network-pfsense",
  "title": "Network — pfSense",
  "description": "pfSense firewall metrics via SNMP if_mib + ucd_*: interfaces, load, memory, CPU.",
  "tags": ["infrastructure", "snmp", "pfsense", "firewall"],
  "schemaVersion": 38,
  "version": 1,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "liveNow": false,
  "fiscalYearStartMonth": 0,
  "weekStart": "",
  "links": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Uptime",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sysUpTime{job=\"snmp-pfsense\"} / 100", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Load (1m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "laLoadInt{job=\"snmp-pfsense\", laNames=\"Load-1\"} / 100", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Load (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": {
        "colorMode": "value", "graphMode": "area", "justifyMode": "auto",
        "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "laLoadInt{job=\"snmp-pfsense\", laNames=\"Load-5\"} / 100", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Memory Used %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] },
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 * (1 - memAvailReal{job=\"snmp-pfsense\"} / memTotalReal{job=\"snmp-pfsense\"})", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Swap Used %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 25 }, { "color": "red", "value": 50 }] },
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 * (1 - memAvailSwap{job=\"snmp-pfsense\"} / memTotalSwap{job=\"snmp-pfsense\"})", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Interface Throughput — WAN/LAN (bits/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto",
            "barAlignment": 0, "drawStyle": "line", "fillOpacity": 10, "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth", "lineWidth": 1, "pointSize": 5,
            "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "bps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(ifHCInOctets{job=\"snmp-pfsense\",ifName!~\"lo.*|pflog.*|pfsync.*|enc.*\"}[5m]) * 8",
          "legendFormat": "rx {{ifName}} {{ifAlias}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "-rate(ifHCOutOctets{job=\"snmp-pfsense\",ifName!~\"lo.*|pflog.*|pfsync.*|enc.*\"}[5m]) * 8",
          "legendFormat": "tx {{ifName}} {{ifAlias}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU Load (1/5/15m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto",
            "barAlignment": 0, "drawStyle": "line", "fillOpacity": 10, "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth", "lineWidth": 1, "pointSize": 5,
            "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "laLoadInt{job=\"snmp-pfsense\"} / 100", "legendFormat": "{{laNames}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory Breakdown",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto",
            "barAlignment": 0, "drawStyle": "line", "fillOpacity": 30, "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth", "lineWidth": 1, "pointSize": 5,
            "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }, "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(memTotalReal{job=\"snmp-pfsense\"} - memAvailReal{job=\"snmp-pfsense\"}) * 1024", "legendFormat": "used", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "memBuffer{job=\"snmp-pfsense\"} * 1024", "legendFormat": "buffers", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "memCached{job=\"snmp-pfsense\"} * 1024", "legendFormat": "cached", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "memAvailReal{job=\"snmp-pfsense\"} * 1024", "legendFormat": "available", "refId": "D" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "CPU Time Distribution (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto",
            "barAlignment": 0, "drawStyle": "line", "fillOpacity": 10, "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth", "lineWidth": 1, "pointSize": 5,
            "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ssCpuIdle{job=\"snmp-pfsense\"}", "legendFormat": "idle", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ssCpuSystem{job=\"snmp-pfsense\"}", "legendFormat": "system", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ssCpuUser{job=\"snmp-pfsense\"}", "legendFormat": "user", "refId": "C" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Process / Context-Switch Activity",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto",
            "barAlignment": 0, "drawStyle": "line", "fillOpacity": 10, "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth", "lineWidth": 1, "pointSize": 5,
            "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "cps"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(ssRawContexts{job=\"snmp-pfsense\"}[5m])", "legendFormat": "ctx/s", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(ssRawInterrupts{job=\"snmp-pfsense\"}[5m])", "legendFormat": "int/s", "refId": "B" }
      ]
    }
  ]
}
