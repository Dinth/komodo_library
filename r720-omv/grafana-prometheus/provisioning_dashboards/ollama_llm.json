        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(ollama_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p95", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(ollama_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p99", "refId": "C" }
